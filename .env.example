# LLM_API_BASE_URL: OpenAI-compatible API base URL.
LLM_API_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# LLM_API_KEY: API key for the selected model provider.
LLM_API_KEY="YOUR_API_KEY"

# LLM_MODEL: Model name used by the frontend AI requests.
LLM_MODEL="qwen-plus"

# GEMINI_API_KEY: Used for Gemini AI fallback or primary usage.
GEMINI_API_KEY=""

# DEEPSEEK_API_KEY: Used in Stage 6 for advanced text processing.
DEEPSEEK_API_KEY=""

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
